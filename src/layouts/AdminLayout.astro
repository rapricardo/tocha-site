---
import '../styles/global.css';

interface Props {
  title: string;
  activeSection?: 'dashboard' | 'produtos' | 'aulas' | 'turmas' | 'lives' | 'usuarios' | 'pagamentos';
}

const { title, activeSection = 'dashboard' } = Astro.props;

const navItems: Array<{ key: NonNullable<Props['activeSection']>; label: string; href: string }> = [
  { key: 'dashboard', label: 'Dashboard', href: '/admin/' },
  { key: 'produtos', label: 'Produtos', href: '/admin/produtos/' },
  { key: 'aulas', label: 'Aulas', href: '/admin/aulas/' },
  { key: 'turmas', label: 'Turmas', href: '/admin/turmas/' },
  { key: 'lives', label: 'Lives', href: '/admin/lives/' },
  { key: 'usuarios', label: 'Usuários', href: '/admin/usuarios/' },
  { key: 'pagamentos', label: 'Pagamentos', href: '/admin/pagamentos/' },
];
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&family=Space+Grotesk:wght@400;500;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
    <style>
      body {
        font-family: 'Inter', sans-serif;
        background-color: #0a0a0a;
        color: #e5e7eb;
      }
      h1, h2, h3, h4, h5, h6, .font-industrial {
        font-family: 'Space Grotesk', sans-serif;
      }
      .font-mono {
        font-family: 'JetBrains Mono', ui-monospace, monospace;
      }
      ::-webkit-scrollbar {
        width: 10px;
      }
      ::-webkit-scrollbar-track {
        background: #111;
      }
      ::-webkit-scrollbar-thumb {
        background: #333;
        border: 1px solid #444;
      }
      ::-webkit-scrollbar-thumb:hover {
        background: #eab308;
      }
    </style>
  </head>
  <body class="bg-[#0a0a0a] text-gray-300">
    <div class="min-h-screen flex flex-col">
      <!-- Top bar -->
      <header class="bg-black border-b border-gray-800 px-6 py-4 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <div class="w-1 h-6 bg-yellow-500"></div>
          <span class="font-industrial uppercase text-white tracking-widest text-sm">
            Ricardo Tocha <span class="text-yellow-500">/</span> Admin
          </span>
        </div>
        <div class="flex items-center gap-6">
          <a
            href="/membros/"
            class="text-xs font-mono uppercase tracking-wider text-gray-500 hover:text-yellow-500 transition-colors"
          >
            Voltar ao site
          </a>
          <form method="POST" action="/api/auth/logout">
            <button
              type="submit"
              class="text-xs font-mono uppercase tracking-wider text-gray-500 hover:text-red-500 transition-colors"
            >
              Sair
            </button>
          </form>
        </div>
      </header>

      <div class="flex-1 flex">
        <!-- Sidebar -->
        <aside class="w-56 bg-[#0f0f0f] border-r border-gray-800 py-6">
          <nav class="flex flex-col">
            {navItems.map((item) => {
              const isActive = item.key === activeSection;
              return (
                <a
                  href={item.href}
                  class={`px-6 py-3 text-xs font-mono uppercase tracking-wider border-l-2 transition-colors ${
                    isActive
                      ? 'border-yellow-500 bg-yellow-500/5 text-yellow-500'
                      : 'border-transparent text-gray-400 hover:text-white hover:border-gray-600'
                  }`}
                >
                  {item.label}
                </a>
              );
            })}
          </nav>
        </aside>

        <!-- Main content -->
        <main class="flex-1 p-8 overflow-x-auto">
          <slot />
        </main>
      </div>
    </div>
  </body>
</html>
