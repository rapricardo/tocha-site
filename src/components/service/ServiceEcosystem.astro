---
interface Props {
  currentTool: 'athena' | 'apolo' | 'apexmkt';
}

const { currentTool } = Astro.props;

const tools = {
  athena: {
    name: "Auditoria Comercial por IA",
    subtitle: "ATHENA • athena.app.br",
    href: "/auditoria-comercial-ia/",
    description:
      "Intercepta e analisa 100% das conversas de vendas no WhatsApp. Cruza com o CRM e entrega à diretoria um raio-x completo de SLAs e aderência ao playbook.",
    icon: "sparkles",
  },
  apolo: {
    name: "Prospecção Inteligente via WhatsApp",
    subtitle: "APOLO • apolo.api.br",
    href: "/prospeccao-whatsapp-ia/",
    description:
      "IA que monitora grupos de WhatsApp 24/7, identifica intenções de compra em tempo real e aborda o lead no direct automaticamente. Custo por lead: R$ 0.",
    icon: "zap",
  },
  apexmkt: {
    name: "Operações de Marketing Assistidas por IA",
    subtitle: "APEXMKT • apexmkt.ia.br",
    href: "/operacoes-marketing-ia/",
    description:
      "Cada pessoa da sua operação ganha um assistente de IA. A IA executa, organiza e sugere — reduzindo burocracia e multiplicando a qualidade de entrega.",
    icon: "sparkles",
  },
};

const otherTools = Object.entries(tools).filter(([key]) => key !== currentTool);
---

<section class="py-24 px-6 border-b border-gray-800 bg-[#0a0a0a]">
  <div class="max-w-7xl mx-auto">
    <div class="mb-16">
      <span class="inline-flex items-center gap-2 text-yellow-500 font-mono text-sm mb-4">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
        </svg>
        Uma Peça da Infraestrutura
      </span>
      <h2 class="text-3xl md:text-5xl font-bold font-industrial text-white uppercase tracking-tight leading-none">
        Cada ferramenta resolve uma camada.
      </h2>
      <p class="text-gray-400 mt-4 max-w-2xl">
        Juntas, elas descolam a receita da folha de pagamento.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {otherTools.map(([, tool]) => (
        <div class="flex items-start gap-6 bg-[#111] p-8 md:p-12 border border-gray-800 hover:border-yellow-500/50 transition-all duration-300 group flex-col md:flex-row">
          <div class="shrink-0 p-3 bg-black border border-gray-700 group-hover:border-yellow-500 transition-colors">
            {tool.icon === "zap" ? (
              <svg class="w-6 h-6 text-yellow-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            ) : (
              <svg class="w-6 h-6 text-yellow-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" />
              </svg>
            )}
          </div>
          <div>
            <h3 class="text-2xl font-bold font-industrial text-white uppercase tracking-tight mb-1">{tool.name}</h3>
            <p class="text-yellow-500 uppercase tracking-widest text-xs font-mono mb-4">{tool.subtitle}</p>
            <p class="text-gray-400 leading-relaxed mb-4">{tool.description}</p>
            <a href={tool.href} class="inline-flex items-center gap-2 text-yellow-500 text-sm font-bold uppercase tracking-widest hover:text-yellow-400 transition-colors">
              Conhecer
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
