---
import Layout from '../../layouts/Layout.astro';
import { Image } from 'astro:assets';
import logoAmarelo from '../../assets/logo-web-amarelo.webp';
import ServiceEcosystem from '../../components/service/ServiceEcosystem.astro';
import ServiceCTA from '../../components/service/ServiceCTA.astro';
---

<Layout
  title="Auditoria Comercial por IA — Ricardo Tocha"
  description="Audite 100% das conversas de vendas no WhatsApp com IA. Cruze dados com o CRM em tempo real. Elimine o ponto cego da gestão comercial."
>

  <!-- NAV -->
  <nav class="fixed w-full z-50 bg-[#0a0a0a]/90 backdrop-blur-md border-b border-gray-800">
    <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
      <a href="/">
        <Image src={logoAmarelo} alt="Ricardo Tocha" width={160} height={40} class="h-8 w-auto" />
      </a>
      <div class="hidden md:flex items-center gap-4">
        <a href="/#auditoria" class="bg-yellow-500 text-black text-xs font-bold uppercase tracking-widest px-4 py-2 hover:bg-yellow-400 transition-colors">
          Iniciar Diagnóstico
        </a>
      </div>
    </div>
  </nav>

  <div class="max-w-7xl mx-auto px-6 pt-20 pb-4">
    <a href="/" class="inline-block border border-gray-700 text-xs font-bold uppercase tracking-widest text-gray-300 px-4 py-2 hover:bg-white hover:text-black transition-colors">← Voltar para Home</a>
  </div>

  <!-- HERO -->
  <section class="relative min-h-[80vh] flex items-center pt-8 pb-20 px-6 border-b border-gray-800 bg-grid-pattern overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-[#0a0a0a]/50 via-transparent to-[#0a0a0a]"></div>
    <div class="max-w-5xl mx-auto w-full relative z-10 text-center">

      <div class="inline-flex items-center gap-2 border border-yellow-500/30 bg-yellow-500/10 text-yellow-500 text-xs font-bold uppercase tracking-widest font-mono px-4 py-1.5 mb-8">
        ATHENA • athena.app.br
      </div>

      <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold font-industrial text-white uppercase tracking-tight leading-[1.1] mb-8">
        100% das conversas de vendas auditadas por IA.
      </h1>

      <div class="max-w-2xl mx-auto mb-12">
        <p class="text-lg md:text-xl text-gray-400 font-light leading-relaxed">
          Sua diretoria não sabe o que acontece entre o vendedor e o cliente no WhatsApp. O Athena intercepta, analisa e cruza com o CRM — em tempo real. O ponto cego gerencial é erradicado.
        </p>
      </div>

      <a href="/#auditoria" class="inline-flex items-center gap-2 bg-yellow-500 text-black font-bold uppercase tracking-widest px-8 py-4 text-sm hover:bg-yellow-400 transition-colors">
        Aplicar para Intervenção Estratégica
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
      <p class="text-gray-600 text-xs mt-4 uppercase tracking-widest font-mono">
        Também disponível como SaaS standalone em <a href="https://athena.app.br/" target="_blank" rel="noopener noreferrer" class="text-yellow-600 hover:text-yellow-500 transition-colors">athena.app.br</a>
      </p>

    </div>
  </section>

  <!-- O PROBLEMA -->
  <section class="py-24 px-6 border-b border-gray-800 bg-[#0f0f0f]">
    <div class="max-w-7xl mx-auto">
      <div class="mb-16">
        <span class="inline-flex items-center gap-2 text-yellow-500 font-mono text-sm mb-4">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          O Problema
        </span>
        <h2 class="text-3xl md:text-5xl font-bold font-industrial text-white uppercase tracking-tight max-w-3xl leading-none">
          Por que sua gestão comercial opera no escuro.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

        <!-- Card 1: Operação no Escuro -->
        <div class="border border-gray-800 p-8 hover:border-yellow-500/50 transition-colors bg-[#0a0a0a]">
          <div class="shrink-0 p-3 bg-black border border-gray-700 inline-block mb-4">
            <!-- Eye-off icon -->
            <svg class="w-6 h-6 text-yellow-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88" />
            </svg>
          </div>
          <h3 class="text-xl font-bold font-industrial text-white uppercase tracking-tight mb-3">Operação no Escuro</h3>
          <p class="text-gray-400 text-sm leading-relaxed">Sua equipe comercial opera no WhatsApp. Sua diretoria opera no achismo. Nenhum gestor audita 100% das conversas — e os 10% que chegam são os que o vendedor escolheu mostrar.</p>
        </div>

        <!-- Card 2: CRM Mentiroso -->
        <div class="border border-gray-800 p-8 hover:border-yellow-500/50 transition-colors bg-[#0a0a0a]">
          <div class="shrink-0 p-3 bg-black border border-gray-700 inline-block mb-4">
            <!-- Database icon -->
            <svg class="w-6 h-6 text-yellow-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 5.625c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125" />
            </svg>
          </div>
          <h3 class="text-xl font-bold font-industrial text-white uppercase tracking-tight mb-3">CRM Mentiroso</h3>
          <p class="text-gray-400 text-sm leading-relaxed">O vendedor preenche o CRM com o que ele quer que você veja, não com o que aconteceu. Oportunidades "perdidas por preço" são, na verdade, perdidas por negligência. Mas você nunca vai saber.</p>
        </div>

        <!-- Card 3: SLAs Quebrados -->
        <div class="border border-gray-800 p-8 hover:border-yellow-500/50 transition-colors bg-[#0a0a0a]">
          <div class="shrink-0 p-3 bg-black border border-gray-700 inline-block mb-4">
            <!-- Clock icon -->
            <svg class="w-6 h-6 text-yellow-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold font-industrial text-white uppercase tracking-tight mb-3">SLAs Quebrados</h3>
          <p class="text-gray-400 text-sm leading-relaxed">Seu marketing gera leads a R$ 80 cada. O comercial responde em 4 horas. O lead já comprou do concorrente. O CAC sobe. A culpa cai no tráfego. O ciclo se repete.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- A INTERVENÇÃO -->
  <section class="py-24 px-6 border-b border-gray-800 bg-[#0a0a0a]">
    <div class="max-w-7xl mx-auto">
      <div class="mb-16">
        <span class="inline-flex items-center gap-2 text-yellow-500 font-mono text-sm mb-4">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" />
          </svg>
          A Intervenção
        </span>
        <h2 class="text-3xl md:text-5xl font-bold font-industrial text-white uppercase tracking-tight max-w-3xl leading-none">
          Como o Athena opera na sua empresa.
        </h2>
      </div>

      <div class="max-w-3xl space-y-10">

        <div class="flex gap-6 items-start">
          <div class="shrink-0 w-10 h-10 bg-yellow-500 text-black flex items-center justify-center font-bold font-industrial text-lg">1</div>
          <div>
            <h3 class="text-lg font-bold font-industrial text-white uppercase tracking-tight mb-2">Diagnóstico de SLAs</h3>
            <p class="text-gray-400 text-sm leading-relaxed">Mapeamento completo dos gargalos: tempo médio de resposta, taxa de follow-up, aderência ao playbook. Dados reais, não autopercepção.</p>
          </div>
        </div>

        <div class="flex gap-6 items-start">
          <div class="shrink-0 w-10 h-10 bg-yellow-500 text-black flex items-center justify-center font-bold font-industrial text-lg">2</div>
          <div>
            <h3 class="text-lg font-bold font-industrial text-white uppercase tracking-tight mb-2">Instalação do Athena</h3>
            <p class="text-gray-400 text-sm leading-relaxed">Interceptação de 100% das conversas de vendas no WhatsApp. Sem instalar nada no celular do vendedor. Sem depender de "print de tela".</p>
          </div>
        </div>

        <div class="flex gap-6 items-start">
          <div class="shrink-0 w-10 h-10 bg-yellow-500 text-black flex items-center justify-center font-bold font-industrial text-lg">3</div>
          <div>
            <h3 class="text-lg font-bold font-industrial text-white uppercase tracking-tight mb-2">Cruzamento com CRM</h3>
            <p class="text-gray-400 text-sm leading-relaxed">Os dados brutos das conversas são cruzados com o pipeline do CRM automaticamente. A discrepância entre o que foi reportado e o que aconteceu fica exposta.</p>
          </div>
        </div>

        <div class="flex gap-6 items-start">
          <div class="shrink-0 w-10 h-10 bg-yellow-500 text-black flex items-center justify-center font-bold font-industrial text-lg">4</div>
          <div>
            <h3 class="text-lg font-bold font-industrial text-white uppercase tracking-tight mb-2">Dashboard para Diretoria</h3>
            <p class="text-gray-400 text-sm leading-relaxed">Raio-x semanal: SLAs de resposta, objeções mais frequentes, aderência ao script, vendedores que convertem vs. vendedores que perdem. Decisão baseada em evidência.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- PROVA: CASE IBREP -->
  <section class="py-24 px-6 border-b border-gray-800 bg-[#0f0f0f]">
    <div class="max-w-7xl mx-auto">
      <div class="mb-16">
        <span class="inline-flex items-center gap-2 text-yellow-500 font-mono text-sm mb-4">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Caso Real
        </span>
        <h2 class="text-3xl md:text-5xl font-bold font-industrial text-white uppercase tracking-tight leading-none">
          IBREP — Auditoria e Recuperação de Margem
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-0 border border-gray-800">

        <div class="p-8 md:p-10 border-b md:border-b-0 md:border-r border-gray-800">
          <p class="text-yellow-500 font-mono text-xs uppercase tracking-widest mb-4">O Sangramento</p>
          <p class="text-gray-300 text-sm leading-relaxed">Leads de alto custo gerados pelo marketing escoavam para um vácuo operacional. A diretoria desconhecia a taxa real de rejeição e a qualidade da argumentação da equipe no WhatsApp.</p>
        </div>

        <div class="p-8 md:p-10 border-b md:border-b-0 md:border-r border-gray-800">
          <p class="text-yellow-500 font-mono text-xs uppercase tracking-widest mb-4">A Intervenção</p>
          <p class="text-gray-300 text-sm leading-relaxed">O Athena assumiu a auditoria integral das interações entre corretores e clientes. O sistema cruzou os dados brutos com o pipeline do CRM em tempo real para expor a realidade da operação.</p>
        </div>

        <div class="p-8 md:p-10">
          <p class="text-yellow-500 font-mono text-xs uppercase tracking-widest mb-4">O Lucro Protegido</p>
          <p class="text-gray-300 text-sm leading-relaxed">O ponto cego gerencial foi erradicado. A conversão de vendas escalou através da imposição rigorosa de SLAs de resposta e correção imediata de rota.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- ECOSSISTEMA DE SERVIÇOS -->
  <ServiceEcosystem currentTool="athena" />

  <!-- CTA FINAL -->
  <ServiceCTA />

</Layout>
