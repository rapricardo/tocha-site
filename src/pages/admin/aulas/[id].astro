---
export const prerender = false;

import AdminLayout from '../../../layouts/AdminLayout.astro';
import { createAdminClient } from '../../../lib/supabase-admin';

const { id } = Astro.params;
if (!id) return Astro.redirect('/admin/aulas/');

const admin = createAdminClient();
const { data: aula, error } = await admin
  .from('lessons')
  .select('*')
  .eq('id', id)
  .single();

if (error || !aula) {
  return Astro.redirect('/admin/aulas/?erro=aula-nao-encontrada');
}

const { data: produtos } = await admin
  .from('products')
  .select('slug, name')
  .eq('active', true)
  .order('name');

const erro = Astro.url.searchParams.get('erro');
const msg = Astro.url.searchParams.get('msg');
---

<AdminLayout title={`Admin — Editar ${aula.title}`} activeSection="aulas">
  <div class="mb-8 flex items-center gap-4">
    <a href="/admin/aulas/" class="text-xs font-mono uppercase tracking-wider text-gray-500 hover:text-yellow-500">
      ← Voltar
    </a>
  </div>

  <h1 class="font-industrial uppercase text-white text-2xl tracking-wider mb-1">
    Editar aula
  </h1>
  <p class="text-gray-500 text-xs font-mono uppercase tracking-wider mb-8">
    ID: {aula.id}
  </p>

  {msg === 'salvo' && (
    <div class="bg-green-500/10 border border-green-500/30 text-green-400 text-sm p-3 mb-6 font-mono max-w-3xl">
      Alterações salvas.
    </div>
  )}
  {erro && (
    <div class="bg-red-500/10 border border-red-500/30 text-red-400 text-sm p-3 mb-6 font-mono max-w-3xl">
      Erro: {erro}
    </div>
  )}

  <form method="POST" action={`/api/admin/aulas/${aula.id}/atualizar`} class="max-w-3xl">
    <div class="bg-[#111] border border-gray-800 p-6 space-y-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-xs font-mono text-gray-500 mb-1 uppercase tracking-wider">Produto *</label>
          <select name="product_slug" required
            class="w-full bg-[#0a0a0a] border border-gray-700 text-white p-3 focus:border-yellow-500 focus:outline-none font-mono text-sm">
            {(produtos || []).map((p) => (
              <option value={p.slug} selected={p.slug === aula.product_slug}>{p.slug} — {p.name}</option>
            ))}
          </select>
        </div>
        <div>
          <label class="block text-xs font-mono text-gray-500 mb-1 uppercase tracking-wider">Slug *</label>
          <input type="text" name="slug" required value={aula.slug}
            class="w-full bg-[#0a0a0a] border border-gray-700 text-white p-3 focus:border-yellow-500 focus:outline-none font-mono text-sm" />
        </div>
      </div>

      <div>
        <label class="block text-xs font-mono text-gray-500 mb-1 uppercase tracking-wider">Título *</label>
        <input type="text" name="title" required value={aula.title}
          class="w-full bg-[#0a0a0a] border border-gray-700 text-white p-3 focus:border-yellow-500 focus:outline-none text-sm" />
      </div>

      <div>
        <label class="block text-xs font-mono text-gray-500 mb-1 uppercase tracking-wider">Descrição</label>
        <textarea name="description" rows="2"
          class="w-full bg-[#0a0a0a] border border-gray-700 text-white p-3 focus:border-yellow-500 focus:outline-none text-sm">{aula.description ?? ''}</textarea>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div>
          <label class="block text-xs font-mono text-gray-500 mb-1 uppercase tracking-wider">Tipo *</label>
          <select name="type" required
            class="w-full bg-[#0a0a0a] border border-gray-700 text-white p-3 focus:border-yellow-500 focus:outline-none font-mono text-sm">
            <option value="video" selected={aula.type === 'video'}>video</option>
            <option value="download" selected={aula.type === 'download'}>download</option>
            <option value="text" selected={aula.type === 'text'}>text</option>
            <option value="live_replay" selected={aula.type === 'live_replay'}>live_replay</option>
          </select>
        </div>
        <div>
          <label class="block text-xs font-mono text-gray-500 mb-1 uppercase tracking-wider">Ordem</label>
          <input type="number" name="order_index" step="1" value={aula.order_index}
            class="w-full bg-[#0a0a0a] border border-gray-700 text-white p-3 focus:border-yellow-500 focus:outline-none font-mono text-sm" />
        </div>
        <div>
          <label class="block text-xs font-mono text-gray-500 mb-1 uppercase tracking-wider">Categoria</label>
          <select name="category"
            class="w-full bg-[#0a0a0a] border border-gray-700 text-white p-3 focus:border-yellow-500 focus:outline-none font-mono text-sm">
            <option value="geral" selected={aula.category === 'geral'}>geral</option>
            <option value="empreendedor" selected={aula.category === 'empreendedor'}>empreendedor</option>
            <option value="empregado" selected={aula.category === 'empregado'}>empregado</option>
          </select>
        </div>
      </div>

      <div>
        <label class="block text-xs font-mono text-gray-500 mb-1 uppercase tracking-wider">
          Referência de conteúdo
        </label>
        <input type="text" name="content_ref" value={aula.content_ref ?? ''}
          class="w-full bg-[#0a0a0a] border border-gray-700 text-white p-3 focus:border-yellow-500 focus:outline-none font-mono text-sm" />
      </div>

      <div>
        <label class="block text-xs font-mono text-gray-500 mb-1 uppercase tracking-wider">
          Resumo em markdown
        </label>
        <textarea name="summary_md" rows="10"
          class="w-full bg-[#0a0a0a] border border-gray-700 text-white p-3 focus:border-yellow-500 focus:outline-none text-sm font-mono">{aula.summary_md ?? ''}</textarea>
      </div>

      <div class="flex items-center gap-3">
        <input type="checkbox" name="is_free" id="is_free" value="on" checked={aula.is_free}
          class="w-4 h-4 accent-yellow-500" />
        <label for="is_free" class="text-xs font-mono text-gray-400 uppercase tracking-wider">
          Aula gratuita
        </label>
      </div>
    </div>

    <div class="mt-6 flex items-center gap-4">
      <button type="submit"
        class="bg-yellow-500 hover:bg-yellow-400 text-black font-bold py-3 px-6 uppercase tracking-widest text-xs transition-colors">
        Salvar alterações
      </button>
      <a href="/admin/aulas/" class="text-xs font-mono uppercase tracking-wider text-gray-500 hover:text-white">
        Cancelar
      </a>
    </div>
  </form>

  <form method="POST" action={`/api/admin/aulas/${aula.id}/deletar`} class="max-w-3xl mt-10">
    <div class="bg-red-500/5 border border-red-500/20 p-6">
      <h3 class="font-industrial uppercase text-red-500 text-sm tracking-wider mb-2">
        Remover aula
      </h3>
      <p class="text-gray-500 text-xs font-mono mb-4">
        Remove definitivamente a aula do banco.
      </p>
      <button type="submit" onclick="return confirm('Remover definitivamente esta aula?')"
        class="border border-red-500/40 text-red-400 hover:bg-red-500/10 font-bold py-2 px-4 uppercase tracking-widest text-xs transition-colors">
        Remover
      </button>
    </div>
  </form>
</AdminLayout>
