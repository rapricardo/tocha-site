---
export const prerender = false;

import AdminLayout from '../../../layouts/AdminLayout.astro';
import { createAdminClient } from '../../../lib/supabase-admin';

const { id } = Astro.params;
if (!id) return Astro.redirect('/admin/lives/');

const admin = createAdminClient();
const { data: live, error } = await admin
  .from('events')
  .select('*')
  .eq('id', id)
  .single();

if (error || !live) {
  return Astro.redirect('/admin/lives/?erro=live-nao-encontrada');
}

const erro = Astro.url.searchParams.get('erro');
const msg = Astro.url.searchParams.get('msg');

// Converte ISO para formato datetime-local (YYYY-MM-DDTHH:mm) no fuso local
const toDatetimeLocal = (iso: string): string => {
  const d = new Date(iso);
  const pad = (n: number) => String(n).padStart(2, '0');
  const yyyy = d.getFullYear();
  const mm = pad(d.getMonth() + 1);
  const dd = pad(d.getDate());
  const hh = pad(d.getHours());
  const mi = pad(d.getMinutes());
  return `${yyyy}-${mm}-${dd}T${hh}:${mi}`;
};

const startsAtLocal = toDatetimeLocal(live.starts_at);
---

<AdminLayout title={`Admin — Editar ${live.title}`} activeSection="lives">
  <div class="mb-8 flex items-center gap-4">
    <a href="/admin/lives/" class="text-xs font-mono uppercase tracking-wider text-gray-500 hover:text-yellow-500">
      ← Voltar
    </a>
  </div>

  <h1 class="font-industrial uppercase text-white text-2xl tracking-wider mb-1">
    Editar live
  </h1>
  <p class="text-gray-500 text-xs font-mono uppercase tracking-wider mb-8">
    ID: {live.id}
  </p>

  {msg === 'salvo' && (
    <div class="bg-green-500/10 border border-green-500/30 text-green-400 text-sm p-3 mb-6 font-mono max-w-3xl">
      Alterações salvas.
    </div>
  )}
  {erro && (
    <div class="bg-red-500/10 border border-red-500/30 text-red-400 text-sm p-3 mb-6 font-mono max-w-3xl">
      Erro: {erro}
    </div>
  )}

  <form method="POST" action={`/api/admin/lives/${live.id}/atualizar`} class="max-w-3xl">
    <div class="bg-[#111] border border-gray-800 p-6 space-y-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-xs font-mono text-gray-500 mb-1 uppercase tracking-wider">Slug *</label>
          <input type="text" name="slug" required value={live.slug}
            class="w-full bg-[#0a0a0a] border border-gray-700 text-white p-3 focus:border-yellow-500 focus:outline-none font-mono text-sm" />
        </div>
        <div>
          <label class="block text-xs font-mono text-gray-500 mb-1 uppercase tracking-wider">Título *</label>
          <input type="text" name="title" required value={live.title}
            class="w-full bg-[#0a0a0a] border border-gray-700 text-white p-3 focus:border-yellow-500 focus:outline-none text-sm" />
        </div>
      </div>

      <div>
        <label class="block text-xs font-mono text-gray-500 mb-1 uppercase tracking-wider">Descrição</label>
        <textarea name="description" rows="4"
          class="w-full bg-[#0a0a0a] border border-gray-700 text-white p-3 focus:border-yellow-500 focus:outline-none text-sm">{live.description ?? ''}</textarea>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-xs font-mono text-gray-500 mb-1 uppercase tracking-wider">Data e hora *</label>
          <input type="datetime-local" name="starts_at" required value={startsAtLocal}
            class="w-full bg-[#0a0a0a] border border-gray-700 text-white p-3 focus:border-yellow-500 focus:outline-none font-mono text-sm" />
        </div>
        <div>
          <label class="block text-xs font-mono text-gray-500 mb-1 uppercase tracking-wider">Duração (min)</label>
          <input type="number" name="duration_minutes" step="1" value={live.duration_minutes ?? 60}
            class="w-full bg-[#0a0a0a] border border-gray-700 text-white p-3 focus:border-yellow-500 focus:outline-none font-mono text-sm" />
        </div>
      </div>

      <div>
        <label class="block text-xs font-mono text-gray-500 mb-1 uppercase tracking-wider">Link do Meet / Zoom</label>
        <input type="text" name="meet_url" value={live.meet_url ?? ''}
          class="w-full bg-[#0a0a0a] border border-gray-700 text-white p-3 focus:border-yellow-500 focus:outline-none font-mono text-sm" />
      </div>

      <div>
        <label class="block text-xs font-mono text-gray-500 mb-1 uppercase tracking-wider">
          YouTube ID da gravação
        </label>
        <input type="text" name="recording_youtube_id" value={live.recording_youtube_id ?? ''}
          class="w-full bg-[#0a0a0a] border border-gray-700 text-white p-3 focus:border-yellow-500 focus:outline-none font-mono text-sm" />
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-xs font-mono text-gray-500 mb-1 uppercase tracking-wider">Categoria</label>
          <select name="category"
            class="w-full bg-[#0a0a0a] border border-gray-700 text-white p-3 focus:border-yellow-500 focus:outline-none font-mono text-sm">
            <option value="geral" selected={live.category === 'geral'}>geral</option>
            <option value="empreendedor" selected={live.category === 'empreendedor'}>empreendedor</option>
            <option value="empregado" selected={live.category === 'empregado'}>empregado</option>
          </select>
        </div>
        <div>
          <label class="block text-xs font-mono text-gray-500 mb-1 uppercase tracking-wider">Visibilidade</label>
          <select name="visibility"
            class="w-full bg-[#0a0a0a] border border-gray-700 text-white p-3 focus:border-yellow-500 focus:outline-none font-mono text-sm">
            <option value="members" selected={live.visibility === 'members'}>members</option>
            <option value="public" selected={live.visibility === 'public'}>public</option>
            <option value="mentoring_only" selected={live.visibility === 'mentoring_only'}>mentoring_only</option>
          </select>
        </div>
      </div>
    </div>

    <div class="mt-6 flex items-center gap-4">
      <button type="submit"
        class="bg-yellow-500 hover:bg-yellow-400 text-black font-bold py-3 px-6 uppercase tracking-widest text-xs transition-colors">
        Salvar alterações
      </button>
      <a href="/admin/lives/" class="text-xs font-mono uppercase tracking-wider text-gray-500 hover:text-white">
        Cancelar
      </a>
    </div>
  </form>

  <form method="POST" action={`/api/admin/lives/${live.id}/deletar`} class="max-w-3xl mt-10">
    <div class="bg-red-500/5 border border-red-500/20 p-6">
      <h3 class="font-industrial uppercase text-red-500 text-sm tracking-wider mb-2">
        Remover live
      </h3>
      <p class="text-gray-500 text-xs font-mono mb-4">
        Remove definitivamente o evento do banco.
      </p>
      <button type="submit" onclick="return confirm('Remover definitivamente esta live?')"
        class="border border-red-500/40 text-red-400 hover:bg-red-500/10 font-bold py-2 px-4 uppercase tracking-widest text-xs transition-colors">
        Remover
      </button>
    </div>
  </form>
</AdminLayout>
