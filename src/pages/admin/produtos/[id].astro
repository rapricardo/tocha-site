---
export const prerender = false;

import AdminLayout from '../../../layouts/AdminLayout.astro';
import { createAdminClient } from '../../../lib/supabase-admin';

const { id } = Astro.params;
if (!id) return Astro.redirect('/admin/produtos/');

const admin = createAdminClient();
const { data: produto, error } = await admin
  .from('products')
  .select('*')
  .eq('id', id)
  .single();

if (error || !produto) {
  return Astro.redirect('/admin/produtos/?erro=produto-nao-encontrado');
}

const erro = Astro.url.searchParams.get('erro');
const msg = Astro.url.searchParams.get('msg');

const includesProducts = Array.isArray(produto.includes_products)
  ? produto.includes_products.join(', ')
  : '';
---

<AdminLayout title={`Admin — Editar ${produto.name}`} activeSection="produtos">
  <div class="mb-8 flex items-center gap-4">
    <a
      href="/admin/produtos/"
      class="text-xs font-mono uppercase tracking-wider text-gray-500 hover:text-yellow-500"
    >
      ← Voltar
    </a>
  </div>

  <h1 class="font-industrial uppercase text-white text-2xl tracking-wider mb-1">
    Editar produto
  </h1>
  <p class="text-gray-500 text-xs font-mono uppercase tracking-wider mb-8">
    ID: {produto.id}
  </p>

  {msg === 'salvo' && (
    <div class="bg-green-500/10 border border-green-500/30 text-green-400 text-sm p-3 mb-6 font-mono max-w-3xl">
      Alterações salvas.
    </div>
  )}
  {erro && (
    <div class="bg-red-500/10 border border-red-500/30 text-red-400 text-sm p-3 mb-6 font-mono max-w-3xl">
      Erro: {erro}
    </div>
  )}

  <form method="POST" action={`/api/admin/produtos/${produto.id}/atualizar`} class="max-w-3xl">
    <div class="bg-[#111] border border-gray-800 p-6 space-y-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-xs font-mono text-gray-500 mb-1 uppercase tracking-wider">
            Slug *
          </label>
          <input type="text" name="slug" required value={produto.slug}
            class="w-full bg-[#0a0a0a] border border-gray-700 text-white p-3 focus:border-yellow-500 focus:outline-none font-mono text-sm" />
        </div>
        <div>
          <label class="block text-xs font-mono text-gray-500 mb-1 uppercase tracking-wider">
            Nome *
          </label>
          <input type="text" name="name" required value={produto.name}
            class="w-full bg-[#0a0a0a] border border-gray-700 text-white p-3 focus:border-yellow-500 focus:outline-none text-sm" />
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-xs font-mono text-gray-500 mb-1 uppercase tracking-wider">
            Tipo *
          </label>
          <select name="type" required
            class="w-full bg-[#0a0a0a] border border-gray-700 text-white p-3 focus:border-yellow-500 focus:outline-none font-mono text-sm">
            <option value="infoproduct" selected={produto.type === 'infoproduct'}>infoproduct</option>
            <option value="mentoring" selected={produto.type === 'mentoring'}>mentoring</option>
            <option value="live_access" selected={produto.type === 'live_access'}>live_access</option>
          </select>
        </div>
        <div>
          <label class="block text-xs font-mono text-gray-500 mb-1 uppercase tracking-wider">
            Categoria *
          </label>
          <select name="category" required
            class="w-full bg-[#0a0a0a] border border-gray-700 text-white p-3 focus:border-yellow-500 focus:outline-none font-mono text-sm">
            <option value="geral" selected={produto.category === 'geral'}>geral</option>
            <option value="empreendedor" selected={produto.category === 'empreendedor'}>empreendedor</option>
            <option value="empregado" selected={produto.category === 'empregado'}>empregado</option>
          </select>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-xs font-mono text-gray-500 mb-1 uppercase tracking-wider">
            Preço (centavos) *
          </label>
          <input type="number" name="price_cents" required min="0" step="1" value={produto.price_cents}
            class="w-full bg-[#0a0a0a] border border-gray-700 text-white p-3 focus:border-yellow-500 focus:outline-none font-mono text-sm" />
        </div>
        <div>
          <label class="block text-xs font-mono text-gray-500 mb-1 uppercase tracking-wider">
            Máx. parcelas
          </label>
          <input type="number" name="max_installments" min="1" step="1" value={produto.max_installments ?? 1}
            class="w-full bg-[#0a0a0a] border border-gray-700 text-white p-3 focus:border-yellow-500 focus:outline-none font-mono text-sm" />
        </div>
      </div>

      <div>
        <label class="block text-xs font-mono text-gray-500 mb-1 uppercase tracking-wider">
          Caminho de download
        </label>
        <input type="text" name="download_path" value={produto.download_path ?? ''}
          class="w-full bg-[#0a0a0a] border border-gray-700 text-white p-3 focus:border-yellow-500 focus:outline-none font-mono text-sm" />
      </div>

      <div>
        <label class="block text-xs font-mono text-gray-500 mb-1 uppercase tracking-wider">
          Descrição curta
        </label>
        <textarea name="short_description" rows="2"
          class="w-full bg-[#0a0a0a] border border-gray-700 text-white p-3 focus:border-yellow-500 focus:outline-none text-sm">{produto.short_description ?? ''}</textarea>
      </div>

      <div>
        <label class="block text-xs font-mono text-gray-500 mb-1 uppercase tracking-wider">
          Descrição longa
        </label>
        <textarea name="long_description" rows="4"
          class="w-full bg-[#0a0a0a] border border-gray-700 text-white p-3 focus:border-yellow-500 focus:outline-none text-sm">{produto.long_description ?? ''}</textarea>
      </div>

      <div>
        <label class="block text-xs font-mono text-gray-500 mb-1 uppercase tracking-wider">
          Produtos incluídos (slugs separados por vírgula)
        </label>
        <input type="text" name="includes_products" value={includesProducts}
          class="w-full bg-[#0a0a0a] border border-gray-700 text-white p-3 focus:border-yellow-500 focus:outline-none font-mono text-sm" />
      </div>

      <div class="flex items-center gap-3">
        <input type="checkbox" name="active" id="active" value="on" checked={produto.active}
          class="w-4 h-4 accent-yellow-500" />
        <label for="active" class="text-xs font-mono text-gray-400 uppercase tracking-wider">
          Ativo
        </label>
      </div>
    </div>

    <div class="mt-6 flex items-center gap-4">
      <button type="submit"
        class="bg-yellow-500 hover:bg-yellow-400 text-black font-bold py-3 px-6 uppercase tracking-widest text-xs transition-colors">
        Salvar alterações
      </button>
      <a href="/admin/produtos/"
        class="text-xs font-mono uppercase tracking-wider text-gray-500 hover:text-white">
        Cancelar
      </a>
    </div>
  </form>

  <!-- Soft delete -->
  <form method="POST" action={`/api/admin/produtos/${produto.id}/deletar`} class="max-w-3xl mt-10">
    <div class="bg-red-500/5 border border-red-500/20 p-6">
      <h3 class="font-industrial uppercase text-red-500 text-sm tracking-wider mb-2">
        Desativar produto
      </h3>
      <p class="text-gray-500 text-xs font-mono mb-4">
        Marca o produto como inativo (active=false). Não remove dados.
      </p>
      <button type="submit"
        onclick="return confirm('Desativar este produto?')"
        class="border border-red-500/40 text-red-400 hover:bg-red-500/10 font-bold py-2 px-4 uppercase tracking-widest text-xs transition-colors">
        Desativar
      </button>
    </div>
  </form>
</AdminLayout>
