              </label>
              <label class="flex items-center space-x-3 p-3 border border-gray-800 hover:border-gray-600 cursor-pointer transition-colors">
                <input type="radio" name="q5" class="accent-yellow-500 bg-[#0a0a0a] border-gray-700">
                <span class="text-gray-400 text-sm">Quero entender o ROI e o Unit Economics primeiro.</span>
              </label>
              <label class="flex items-center space-x-3 p-3 border border-gray-800 hover:border-gray-600 cursor-pointer transition-colors">
