                                <span class="text-zinc-400 peer-checked:text-white peer-checked:font-bold">SIM</span>
                            </label>
                            <label class="flex-1 flex justify-center items-center p-4 border border-zinc-800 hover:border-zinc-500 cursor-pointer transition-colors text-center">
                                <input type="radio" name="q4" class="hidden peer">
                                <span class="text-zinc-400 peer-checked:text-white peer-checked:font-bold">NÃO</span>
