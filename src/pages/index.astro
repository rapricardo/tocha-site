---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import tochaNovo from '../assets/tocha-novo.webp';
---

<Layout title="Ricardo Tocha | Arquitetura de Operações Híbridas" description="Consultor de operações híbricas. Arquitetura de retenção e crescimento para agências de performance.">
  <section class="relative min-h-screen flex items-center justify-center border-b border-gray-800 overflow-hidden pt-20 pb-20" style="background-color: #0a0a0a;">
    <!-- Background pattern -->
    <div class="absolute inset-0 opacity-10" style="background-image: linear-gradient(to right, #222 1px, transparent 1px), linear-gradient(to bottom, #222 1px, transparent 1px); background-size: 40px 40px;"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-[#0a0a0a]/60 via-transparent to-[#0a0a0a] pointer-events-none"></div>

    <div class="container mx-auto px-6 relative z-10 max-w-6xl">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <!-- Text side -->
        <div>
          <div class="inline-flex items-center gap-2 border border-yellow-500/30 bg-yellow-500/10 px-4 py-1.5 rounded-sm mb-8">
            <span class="text-yellow-500 text-xs font-bold tracking-widest uppercase" style="font-family: 'Space Grotesk', sans-serif;">
              Consultor de Operações Híbridas
            </span>
          </div>

          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-[1.1] mb-6 uppercase tracking-tight" style="font-family: 'Space Grotesk', sans-serif;">
            Ricardo Tocha
          </h1>

          <p class="text-lg md:text-xl text-gray-400 mb-8 leading-relaxed" style="max-width: 48ch;">
            Arquitetura de <strong class="text-white">operações híbridas</strong> — o sistema que conecta tráfego, venda e retenção em um funil previsível e escalável.
          </p>

          <div class="space-y-3 text-sm text-gray-500 mb-10" style="font-family: monospace;">
            <p>↳ Arquitetura de Retenção para Agências</p>
            <p>↳ Automação de Vendas B2B (n8n + IA)</p>
            <p>↳ Growth Loops para Operações Híbridas</p>
          </div>

          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/reduzir-churn-agencias" class="inline-flex items-center justify-center px-8 py-4 bg-yellow-500 hover:bg-yellow-400 text-black font-bold text-base uppercase tracking-wider transition-all" style="clip-path: polygon(10px 0, 100% 0, 100% calc(100% - 10px), calc(100% - 10px) 100%, 0 100%, 0 10px);">
              Ver estudo de caso
            </a>
            <a href="https://wa.me/5511999999999" target="_blank" rel="noreferrer" class="inline-flex items-center justify-center px-8 py-4 border border-gray-700 text-gray-300 font-bold text-base uppercase tracking-wider hover:border-gray-500 hover:text-white transition-colors">
              Falar diretamente
            </a>
          </div>
        </div>

        <!-- Photo side -->
        <div class="flex justify-center lg:justify-end">
          <div class="relative">
            <div class="absolute -inset-4 border-2 border-yellow-500/20 rounded-sm -z-10"></div>
            <div class="absolute -inset-2 border border-yellow-500/10 rounded-sm -z-10"></div>
            <Image
              src={tochaNovo}
              alt="Ricardo Tocha - Consultor de Operações Híbridas"
              width={480}
              class="object-cover grayscale hover:grayscale-0 transition-all duration-500"
              style="width: 100%; max-width: 480px; height: auto; aspect-ratio: 4/5;"
            />
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
