---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import tochaBio from '../assets/tocha-bio.webp';
import logoAmarelo from '../assets/logo-web-amarelo.webp';
---

<Layout title="Ricardo Tocha | Arquitetura de Operações Híbridas" description="Governança Comercial e Infraestrutura de IA para Negócios B2B. Escale a receita. Congele o RH.">

  <!-- BARRA DE NAVEGAÇÃO SUPERIOR -->
  <nav class="fixed w-full z-50 bg-[#0a0a0a]/90 backdrop-blur-md border-b border-gray-800">
    <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
      <a href="/">
        <Image src={logoAmarelo} alt="Ricardo Tocha" width={160} height={40} class="h-8 w-auto" />
      </a>
      <div class="hidden md:flex items-center gap-3">
        <a href="/membros/" class="border border-gray-700 hover:border-yellow-500 text-gray-300 hover:text-yellow-500 text-xs font-bold uppercase tracking-widest px-4 py-2 transition-colors">
          Área de Membros
        </a>
        <a href="#auditoria" class="bg-yellow-500 text-black text-xs font-bold uppercase tracking-widest px-4 py-2 hover:bg-yellow-400 transition-colors">
          Iniciar Diagnóstico
        </a>
      </div>
    </div>
  </nav>

  <!-- DOBRA 1: HERO -->
  <section class="relative min-h-screen flex items-center pt-20 pb-12 px-6 border-b border-gray-800 bg-grid-pattern overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-[#0a0a0a]/50 via-transparent to-[#0a0a0a]"></div>
    <div class="max-w-7xl mx-auto w-full relative z-10">
      <div class="max-w-4xl">
        <!-- PRE-HEADLINE -->
        <div class="inline-flex items-center gap-2 border border-yellow-500/30 bg-yellow-500/10 text-yellow-500 text-xs font-bold uppercase tracking-widest px-4 py-1.5 mb-8 animate-fade-in-up">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
          Governança Comercial e Infraestrutura de IA para Negócios B2B
        </div>

        <!-- HEADLINE -->
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold font-industrial text-white uppercase tracking-tight leading-[1.1] mb-8 animate-fade-in-up">
          Eu descolo o
          <span class="text-yellow-500 bg-yellow-900/20 px-2">crescimento</span> da
          sua empresa da necessidade de
          contratar.
        </h1>

        <!-- SUB-HEADLINE -->
        <div class="max-w-2xl mb-12 border-l-2 border-yellow-500/50 pl-6 animate-fade-in-up">
          <p class="text-lg md:text-xl text-gray-400 font-light leading-relaxed">
            Eu construo a infraestrutura de dados e IA que audita 100% da sua operação de vendas e dá superpoderes aos seus melhores talentos.
          </p>
        </div>

        <!-- CALL TO ACTION -->
        <a href="#auditoria" class="group relative inline-block bg-yellow-500 hover:bg-yellow-400 text-black font-bold uppercase tracking-widest px-8 py-4 text-sm md:text-base transition-all animate-fade-in-up" style="clip-path: polygon(10px 0, 100% 0, 100% calc(100% - 10px), calc(100% - 10px) 100%, 0 100%, 0 10px);">
          Aplicar para Intervenção Estratégica
          <svg class="inline-block w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </a>
        <p class="text-gray-600 text-xs mt-4 uppercase tracking-widest font-mono">
          * Apenas para operações com faturamento superior a R$ 5M/ano.
        </p>
      </div>
    </div>
  </section>

  <!-- DOBRA 2: O MANIFESTO DE GOVERNANÇA -->
  <section class="py-24 px-6 border-b border-gray-800 bg-[#0f0f0f]">
    <div class="max-w-7xl mx-auto">
      <div class="mb-16">
        <span class="inline-flex items-center gap-2 text-yellow-500 font-mono text-sm mb-4">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          O Diagnóstico
        </span>
        <h2 class="text-3xl md:text-5xl font-bold font-industrial text-white uppercase tracking-tight max-w-3xl leading-none">
          A sua operação de vendas é uma caixa preta.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 relative">
        <!-- Linha conectora -->
        <div class="hidden md:block absolute top-12 left-[16%] right-[16%] h-0.5 bg-gradient-to-r from-green-900 via-yellow-900 to-red-900"></div>

        <!-- Bloco 1 -->
        <div class="relative z-10 bg-[#0a0a0a] p-8 border border-gray-800 hover:border-gray-600 transition-colors group">
          <div class="w-16 h-16 bg-green-900/20 border border-green-700/50 mb-6 flex items-center justify-center group-hover:bg-green-900/30 transition-colors">
            <svg class="w-7 h-7 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          </div>
          <h3 class="text-white font-bold text-lg mb-4 uppercase tracking-widest font-industrial border-b border-gray-800 pb-4">01. A Ilusão do Dado</h3>
          <p class="text-gray-400 text-sm leading-relaxed">
            A realidade das negociações acontece no WhatsApp, fora do alcance da diretoria. Leads caríssimos morrem no silêncio operacional da equipe comercial. Sem auditoria em tempo real, o seu CAC vira dinheiro queimado.
          </p>
        </div>

        <!-- Bloco 2 -->
        <div class="relative z-10 bg-[#0a0a0a] p-8 border border-gray-800 hover:border-gray-600 transition-colors group">
          <div class="w-16 h-16 bg-yellow-900/20 border border-yellow-700/50 mb-6 flex items-center justify-center group-hover:bg-yellow-900/30 transition-colors">
            <svg class="w-7 h-7 text-yellow-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" /></svg>
          </div>
          <h3 class="text-white font-bold text-lg mb-4 uppercase tracking-widest font-industrial border-b border-gray-800 pb-4">02. O Desperdício de Talento</h3>
          <p class="text-gray-400 text-sm leading-relaxed">
            Seus A-Players gastam energia cobrando SLAs básicos e gerenciando falhas de funcionários medianos. A incompetência operacional da base drena o caixa e sabota o fechamento de grandes contratos.
          </p>
        </div>

        <!-- Bloco 3 -->
        <div class="relative z-10 bg-[#0a0a0a] p-8 border border-gray-800 hover:border-gray-600 transition-colors group">
          <div class="w-16 h-16 bg-red-900/20 border border-red-700/50 mb-6 flex items-center justify-center group-hover:bg-red-900/30 transition-colors">
            <svg class="w-7 h-7 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" /></svg>
          </div>
          <h3 class="text-white font-bold text-lg mb-4 uppercase tracking-widest font-industrial border-b border-gray-800 pb-4">03. O Colapso da Margem</h3>
          <p class="text-gray-400 text-sm leading-relaxed">
            Escalar inflando o quadro de funcionários destrói o Unit Economics. Cada cadeira nova multiplica atrito, inflaciona o OPEX e aumenta o passivo trabalhista.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- DOBRA 3: O ARSENAL -->
  <section class="py-24 px-6 border-b border-gray-800 bg-[#0a0a0a] relative overflow-hidden">
    <div class="absolute top-0 right-0 w-1/3 h-full bg-yellow-500/5 -skew-x-12 transform origin-top-right"></div>
    <div class="max-w-7xl mx-auto relative z-10">
      <div class="mb-16">
        <span class="inline-flex items-center gap-2 text-yellow-500 font-mono text-sm mb-4">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17l-5.384 3.18A1 1 0 015 17.482V6.518a1 1 0 011.036-.868l5.384 3.18m0 0l5.384-3.18A1 1 0 0118 6.518v10.964a1 1 0 01-1.036.868l-5.384-3.18z" /></svg>
          A Infraestrutura
        </span>
        <h2 class="text-3xl md:text-5xl font-bold font-industrial text-white uppercase tracking-tight max-w-4xl leading-none">
          A tecnologia para descolar a receita da folha de pagamento.
        </h2>
        <div class="h-1 w-24 bg-yellow-500 mt-6"></div>
      </div>

      <div class="space-y-6">
        <!-- Arsenal 1 -->
        <div class="flex items-start gap-6 bg-[#111] p-8 md:p-12 border border-gray-800 hover:border-yellow-500/50 transition-all duration-300 group flex-col md:flex-row">
          <div class="shrink-0 p-3 bg-black border border-gray-700 group-hover:border-yellow-500 transition-colors">
            <svg class="w-6 h-6 text-yellow-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" /></svg>
          </div>
          <div>
            <h3 class="text-2xl font-bold font-industrial text-white uppercase tracking-tight mb-1">Auditoria Comercial por IA</h3>
            <p class="text-yellow-500 uppercase tracking-widest text-xs font-mono mb-4">athena.app.br</p>
            <p class="text-gray-400 leading-relaxed mb-4">
              O Athena intercepta e analisa 100% das conversas de vendas no WhatsApp em tempo real. Cruza os dados com o CRM automaticamente e entrega à diretoria um raio-x completo de SLAs, objeções e aderência ao playbook.
            </p>
            <a href="/auditoria-comercial-ia/" class="inline-flex items-center gap-2 text-yellow-500 text-sm font-bold uppercase tracking-widest hover:text-yellow-400 transition-colors">
              Conhecer o Athena
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
            </a>
            <a href="https://athena.app.br/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-gray-500 text-xs font-mono uppercase tracking-widest hover:text-yellow-500 transition-colors ml-4">
              Acessar SaaS
              <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" /></svg>
            </a>
          </div>
        </div>

        <!-- Arsenal 2 -->
        <div class="flex items-start gap-6 bg-[#111] p-8 md:p-12 border border-gray-800 hover:border-yellow-500/50 transition-all duration-300 group flex-col md:flex-row">
          <div class="shrink-0 p-3 bg-black border border-gray-700 group-hover:border-yellow-500 transition-colors">
            <svg class="w-6 h-6 text-yellow-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
          </div>
          <div>
            <h3 class="text-2xl font-bold font-industrial text-white uppercase tracking-tight mb-1">Prospecção Inteligente via WhatsApp</h3>
            <p class="text-yellow-500 uppercase tracking-widest text-xs font-mono mb-4">angulo.ia.br</p>
            <p class="text-gray-400 leading-relaxed mb-4">
              IA de vendas que monitora grupos de WhatsApp 24/7, identifica intenções de compra em tempo real e aborda o lead no direct automaticamente. Sem custo por clique, sem prospecção manual.
            </p>
            <a href="/prospeccao-whatsapp-ia/" class="inline-flex items-center gap-2 text-yellow-500 text-sm font-bold uppercase tracking-widest hover:text-yellow-400 transition-colors">
              Conhecer o Ângulo
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
            </a>
            <a href="https://angulo.ia.br/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-gray-500 text-xs font-mono uppercase tracking-widest hover:text-yellow-500 transition-colors ml-4">
              Acessar SaaS
              <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" /></svg>
            </a>
          </div>
        </div>

        <!-- Arsenal 3 -->
        <div class="flex items-start gap-6 bg-[#111] p-8 md:p-12 border border-gray-800 hover:border-yellow-500/50 transition-all duration-300 group flex-col md:flex-row">
          <div class="shrink-0 p-3 bg-black border border-gray-700 group-hover:border-yellow-500 transition-colors">
            <svg class="w-6 h-6 text-yellow-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" /></svg>
          </div>
          <div>
            <h3 class="text-2xl font-bold font-industrial text-white uppercase tracking-tight mb-1">Operações de Marketing Assistidas por IA</h3>
            <p class="text-yellow-500 uppercase tracking-widest text-xs font-mono mb-4">apexmkt.ia.br</p>
            <p class="text-gray-400 leading-relaxed mb-4">
              Cada pessoa da sua agência ganha um assistente de IA. A IA executa, organiza e sugere — reduzindo burocracia e multiplicando a qualidade de entrega por ciclo.
            </p>
            <a href="/operacoes-marketing-ia/" class="inline-flex items-center gap-2 text-yellow-500 text-sm font-bold uppercase tracking-widest hover:text-yellow-400 transition-colors">
              Conhecer o Apex MKT
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
            </a>
            <a href="https://apexmkt.ia.br/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-gray-500 text-xs font-mono uppercase tracking-widest hover:text-yellow-500 transition-colors ml-4">
              Acessar SaaS
              <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" /></svg>
            </a>
          </div>
        </div>

        <!-- Arsenal 4: MERCÚRIO -->
        <div class="flex items-start gap-6 bg-[#111] p-8 md:p-12 border border-gray-800 hover:border-yellow-500/50 transition-all duration-300 group flex-col md:flex-row">
          <div class="shrink-0 p-3 bg-black border border-gray-700 group-hover:border-yellow-500 transition-colors">
            <svg class="w-6 h-6 text-yellow-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" /></svg>
          </div>
          <div>
            <h3 class="text-2xl font-bold font-industrial text-white uppercase tracking-tight mb-1">Gestão Integrada por IA</h3>
            <p class="text-yellow-500 uppercase tracking-widest text-xs font-mono mb-4">mercurio.ia.br</p>
            <p class="text-gray-400 leading-relaxed mb-4">
              Do comercial ao financeiro, num fluxo só. Proposta, execução e faturamento conectados sem planilhas paralelas, sem retrabalho, sem informação perdida.
            </p>
            <a href="/gestao-integrada-ia/" class="inline-flex items-center gap-2 text-yellow-500 text-sm font-bold uppercase tracking-widest hover:text-yellow-400 transition-colors">
              Conhecer o Mercúrio
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
            </a>
            <a href="https://mercurio.ia.br/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-gray-500 text-xs font-mono uppercase tracking-widest hover:text-yellow-500 transition-colors ml-4">
              Acessar SaaS
              <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" /></svg>
            </a>
          </div>
        </div>

        <!-- Arsenal 5: VÍDEO -->
        <div class="flex items-start gap-6 bg-[#111] p-8 md:p-12 border border-gray-800 hover:border-yellow-500/50 transition-all duration-300 group flex-col md:flex-row">
          <div class="shrink-0 p-3 bg-black border border-gray-700 group-hover:border-yellow-500 transition-colors">
