---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import RedefinirSenhaForm from '../../components/membros/RedefinirSenhaForm';

const erro = Astro.url.searchParams.get('erro');
---

<Layout title="Redefinir Senha — Área de Membros" description="Defina sua nova senha">
  <section class="min-h-screen flex items-center justify-center py-20 px-6">
    <RedefinirSenhaForm erro={erro} client:load />
  </section>
</Layout>
