---
export const prerender = false;

import Layout from '../../../layouts/Layout.astro';

const session = Astro.locals.session!;
---

<Layout title="Download da Máquina" description="Baixe o pacote completo de produção de vídeo com IA">
  <section class="py-20 px-6 min-h-screen">
    <div class="max-w-3xl mx-auto">
      <a href="/membros/" class="text-xs font-mono text-gray-600 hover:text-yellow-500 uppercase tracking-wider transition-colors mb-8 inline-block">
        &larr; Voltar ao painel
      </a>

      <h1 class="text-3xl font-bold font-industrial text-white uppercase mb-2">
        Download da Máquina
      </h1>
      <span class="inline-block text-xs font-mono text-yellow-500 border border-yellow-500/30 bg-yellow-500/10 px-3 py-1 mb-4">CONTEUDO PAGO</span>

      <div class="mt-8 border border-gray-800 bg-gray-900/50 p-8">
        <div class="flex items-start gap-6">
          <div class="shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-yellow-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
            </svg>
          </div>
          <div>
            <h2 class="text-xl font-bold font-industrial text-white uppercase mb-2">Pacote Completo</h2>
            <p class="text-gray-400 text-sm leading-relaxed mb-6">66 arquivos organizados: skills, templates, configurações e exemplos prontos para uso. Extraia, configure o Claude e comece a produzir.</p>
            <form method="POST" action="/api/download">
              <input type="hidden" name="productSlug" value="maquina-videos" />
              <button type="submit" class="inline-block bg-yellow-500 hover:bg-yellow-400 text-black font-bold uppercase tracking-widest px-8 py-4 text-sm transition-all cursor-pointer" style="clip-path: polygon(10px 0, 100% 0, 100% calc(100% - 10px), calc(100% - 10px) 100%, 0 100%, 0 10px);">
                Baixar Máquina &darr;
              </button>
            </form>
          </div>
        </div>
      </div>

      <div class="mt-12 border-t border-gray-800 pt-8">
        <h3 class="text-lg font-bold font-industrial text-white uppercase mb-6">Quick Start</h3>
        <ol class="space-y-4 text-gray-400 text-sm leading-relaxed">
          <li class="flex gap-3">
            <span class="text-yellow-500 font-mono font-bold shrink-0">01</span>
            <span>Extraia o arquivo ZIP em uma pasta dedicada ao projeto</span>
          </li>
          <li class="flex gap-3">
            <span class="text-yellow-500 font-mono font-bold shrink-0">02</span>
            <span>Abra o terminal na pasta e inicie o Claude Code com o projeto</span>
          </li>
          <li class="flex gap-3">
            <span class="text-yellow-500 font-mono font-bold shrink-0">03</span>
            <span>Passe o briefing do cliente como primeiro prompt</span>
          </li>
          <li class="flex gap-3">
            <span class="text-yellow-500 font-mono font-bold shrink-0">04</span>
            <span>Acompanhe a execução das skills e exporte a timeline final</span>
          </li>
        </ol>
      </div>
    </div>
  </section>
</Layout>
